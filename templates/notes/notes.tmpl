<html>
<h1> Notes </h1>

<table>
<thead>
  <tr>
    <th> ID </th>
    <th> Title </th>
    <th> Content </th>
    <th> Created_at </th>
  </tr>
</thead>

<tbody>
  {{ range . }}
  <tr>
    <td> {{ .ID }} </td>
    <td> {{ .Title }} </td>
    <td> {{ .Content }} </td>
    <td> {{ .CreatedAt }} </td>
  </tr>
  {{ else }}
  <tr>
      <td colspan="4">Немає даних для відображення</td>
  </tr>
  {{ end }}
</tbody>

</table>

</html>
